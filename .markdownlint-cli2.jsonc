{
  "config": {
    "default": true,
    "MD013": false,
    "MD024": {
      "siblings_only": true,
    },
    "MD033": false,
  },
  "globs": [
    "*.md",
    ".github/**/*.md",
    "cli/*.md",
    "controller/*.md",
    "docs/**/*.md",
  ],
  "ignores": ["node_modules/**", "controller/.venv/**"],
}
